      <Currency>USD</Currency>
      <DiscountCurve>USD-SOFR</DiscountCurve>
      <Segments>
        <Simple>
          <Type>Deposit</Type>
          <Quotes>
            <Quote>MM/RATE/USD/SOFR/0D/1D</Quote>
